rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is an admin via Custom Auth Claim
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    match /users/{userId} {
      // Users can only read their own profile, admins can read all
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Only admins can modify users
      allow write: if isAdmin();
    }

    match /lists/{listId} {
      // Anyone logged in can read the configuration lists
      allow read: if request.auth != null;
      // Only admins can modify the lists
      allow write: if isAdmin();
    }

    match /calls/{callId} {
      // Anyone logged in can read or write calls (Orientadores submit calls)
      allow read, write: if request.auth != null;
    }

    // Default deny all other collections just in case
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
